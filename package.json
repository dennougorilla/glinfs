{
  "name": "glinfs",
  "version": "0.3.1",
  "description": "High-performance screen capture to GIF converter",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dennougorilla/glinfs.git"
  },
  "keywords": [
    "screen-capture",
    "gif",
    "wasm",
    "web"
  ],
  "author": "dennougorilla",
  "license": "GPL-3.0-only",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "bugs": {
    "url": "https://github.com/dennougorilla/glinfs/issues"
  },
  "homepage": "https://github.com/dennougorilla/glinfs#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@playwright/test": "^1.57.0",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "gifenc": "^1.0.3"
  }
}
